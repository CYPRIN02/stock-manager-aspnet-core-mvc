@model StockManager.Web.Models.Product

@{
    ViewData["Title"] = "Détail produit";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold">@Model.Name</h1>
            <p class="text-muted">Référence : @Model.Reference</p>
        </div>

        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Modifier</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Supprimer</a>
            <a asp-action="Index" class="btn btn-light">Retour</a>
        </div>
    </div>

    <div class="row g-4">

        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">Informations produit</h5>

                    <p><strong>Nom :</strong> @Model.Name</p>
                    <p><strong>Référence :</strong> @Model.Reference</p>
                    <p><strong>Catégorie :</strong> @(Model.Category?.Name ?? "-")</p>
                    <p><strong>Fournisseur :</strong> @(Model.Supplier?.Name ?? "-")</p>
                    <p><strong>Prix unitaire :</strong> @Model.UnitPrice.ToString("C")</p>
                    <p><strong>Quantité :</strong> @Model.Quantity</p>
                    <p><strong>Seuil d’alerte :</strong> @Model.AlertQuantity</p>

                    @if (Model.Quantity <= Model.AlertQuantity)
                    {
                        <span class="badge bg-danger">Produit en alerte stock</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Stock disponible</span>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">Derniers mouvements</h5>

                    @if (Model.StockMovements == null || !Model.StockMovements.Any())
                    {
                        <p class="text-muted">Aucun mouvement pour ce produit.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var movement in Model.StockMovements.Take(5))
                            {
                                <li class="list-group-item d-flex justify-content-between">
                                    <span>
                                        @movement.MovementDate.ToString("dd/MM/yyyy HH:mm")
                                        -
                                        @movement.Reason
                                    </span>

                                    <span class="badge @(movement.Type == StockManager.Web.Models.StockMovementType.Entry ? "bg-success" : "bg-danger")">
                                        @movement.Type - @movement.Quantity
                                    </span>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>

    </div>
</div>