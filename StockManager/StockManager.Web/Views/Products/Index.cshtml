@model IEnumerable<StockManager.Web.Models.Product>

@{
    ViewData["Title"] = "Produits";
}

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold">Produits</h1>
            <p class="text-muted">Liste complète des produits en stock</p>
        </div>

        <a asp-controller="Products" asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Ajouter produit
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body">

            <form method="get" class="row g-2 mb-4">
                <div class="col-md-10">
                    <input type="text"
                           name="search"
                           value="@ViewBag.Search"
                           class="form-control"
                           placeholder="Rechercher par nom ou référence..." />
                </div>

                <div class="col-md-2 d-grid">
                    <button class="btn btn-outline-primary" type="submit">
                        <i class="bi bi-search"></i> Rechercher
                    </button>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Référence</th>
                            <th>Produit</th>
                            <th>Catégorie</th>
                            <th>Fournisseur</th>
                            <th>Quantité</th>
                            <th>Prix unitaire</th>
                            <th>Valeur stock</th>
                            <th>Statut</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var product in Model)
                        {
                            var stockValue = product.Quantity * product.UnitPrice;
                            var isLowStock = product.Quantity <= product.AlertThreshold;

                            <tr>
                                <td class="fw-semibold">@product.Reference</td>
                                <td>@product.Name</td>
                                <td>@product.Category?.Name</td>
                                <td>@product.Supplier?.Name</td>
                                <td>@product.Quantity</td>
                                <td>@product.UnitPrice.ToString("C")</td>
                                <td>@stockValue.ToString("C")</td>
                                <td>
                                    @if (isLowStock)
                                    {
                                        <span class="badge bg-danger">Alerte</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">OK</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>