@model StockManager.Web.Models.Product

@{
    ViewData["Title"] = "Modifier produit";
}

<div class="container py-4">
    <h1 class="fw-bold">Modifier produit</h1>

    <div class="card border-0 shadow-sm mt-3">
        <div class="card-body p-4">

            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label">Nom</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Reference" class="form-label">Référence</label>
                        <input asp-for="Reference" class="form-control" />
                        <span asp-validation-for="Reference" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="CategoryId" class="form-label">Catégorie</label>
                        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select"></select>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="SupplierId" class="form-label">Fournisseur</label>
                        <select asp-for="SupplierId" asp-items="ViewBag.Suppliers" class="form-select"></select>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Quantity" class="form-label">Quantité</label>
                        <input asp-for="Quantity" class="form-control" type="number" />
                    </div>

                    <div class="col-md-4">
                        <label asp-for="UnitPrice" class="form-label">Prix unitaire</label>
                        <input asp-for="UnitPrice" class="form-control" type="number" step="0.01" />
                    </div>

                    <div class="col-md-4">
                        <label asp-for="AlertQuantity" class="form-label">Seuil alerte</label>
                        <input asp-for="AlertQuantity" class="form-control" type="number" />
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a asp-action="Index" class="btn btn-light">Annuler</a>
                    <button type="submit" class="btn btn-primary">Enregistrer</button>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}