@model StockManager.Web.Models.Product

@{
    ViewData["Title"] = "Ajouter un produit";
}

<div class="container py-4">

    <div class="mb-4">
        <h1 class="fw-bold">Ajouter un produit</h1>
        <p class="text-muted">Créer une nouvelle fiche produit</p>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">

                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label">Nom du produit</label>
                        <input asp-for="Name" class="form-control" placeholder="Ex : Clavier Logitech" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Reference" class="form-label">Référence</label>
                        <input asp-for="Reference" class="form-control" placeholder="Ex : PROD-001" />
                        <span asp-validation-for="Reference" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="CategoryId" class="form-label">Catégorie</label>
                        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
                            <option value="">-- Sélectionner une catégorie --</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="SupplierId" class="form-label">Fournisseur</label>
                        <select asp-for="SupplierId" asp-items="ViewBag.Suppliers" class="form-select">
                            <option value="">-- Sélectionner un fournisseur --</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Quantity" class="form-label">Quantité initiale</label>
                        <input asp-for="Quantity" class="form-control" type="number" min="0" />
                    </div>

                    <div class="col-md-4">
                        <label asp-for="UnitPrice" class="form-label">Prix unitaire</label>
                        <input asp-for="UnitPrice" class="form-control" type="number" step="0.01" min="0" />
                    </div>

                    <div class="col-md-4">
                        <label asp-for="AlertQuantity" class="form-label">Seuil d’alerte</label>
                        <input asp-for="AlertQuantity" class="form-control" type="number" min="0" />
                    </div>

                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a asp-action="Index" class="btn btn-light">Annuler</a>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle"></i> Enregistrer
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}