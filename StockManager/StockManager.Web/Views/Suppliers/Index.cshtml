@model IEnumerable<StockManager.Web.Models.Supplier>

@{
    ViewData["Title"] = "Fournisseurs";
    var suppliers = Model ?? Enumerable.Empty<StockManager.Web.Models.Supplier>();
}

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold">Fournisseurs</h1>
            <p class="text-muted">Gestion des fournisseurs</p>
        </div>

        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i>
            Ajouter fournisseur
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body">

            @if (!suppliers.Any())
            {
                <div class="alert alert-info mb-0">
                    Aucun fournisseur enregistré.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Nom</th>
                                <th>Email</th>
                                <th>Téléphone</th>
                                <th>Produits</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var supplier in suppliers)
                            {
                                <tr>
                                    <td class="fw-semibold">
                                        @supplier.Name
                                    </td>

                                    <td>
                                        @(supplier.Email ?? "-")
                                    </td>

                                    <td>
                                        @(supplier.Phone ?? "-")
                                    </td>

                                    <td>
                                        @(supplier.Products?.Count ?? 0)
                                    </td>

                                    <td class="text-end">

                                        <a asp-action="Edit"
                                           asp-route-id="@supplier.Id"
                                           class="btn btn-sm btn-outline-primary">
                                            Modifier
                                        </a>

                                        <a asp-action="Delete"
                                           asp-route-id="@supplier.Id"
                                           class="btn btn-sm btn-outline-danger">
                                            Supprimer
                                        </a>

                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

        </div>
    </div>
</div>