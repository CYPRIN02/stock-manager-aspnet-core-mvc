@model IEnumerable<StockManager.Web.Models.Supplier>

@{
    ViewData["Title"] = "Fournisseurs";
    var suppliers = Model ?? Enumerable.Empty<StockManager.Web.Models.Supplier>();
}

<div class="container-fluid py-4">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold">Fournisseurs</h1>
            <p class="text-muted">Recherche, tri et consultation des fournisseurs</p>
        </div>

        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Ajouter fournisseur
        </a>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">

                <div class="col-md-5">
                    <label class="form-label">Recherche</label>
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Nom, email ou téléphone" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Tri</label>
                    <select name="sortOrder" class="form-select">
                        <option value="name_asc" selected="@(ViewBag.SortOrder == "name_asc")">Nom A-Z</option>
                        <option value="name_desc" selected="@(ViewBag.SortOrder == "name_desc")">Nom Z-A</option>
                        <option value="products_asc" selected="@(ViewBag.SortOrder == "products_asc")">Produits croissant</option>
                        <option value="products_desc" selected="@(ViewBag.SortOrder == "products_desc")">Produits décroissant</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Afficher</label>
                    <select name="pageSize" class="form-select">
                        <option value="25" selected="@(ViewBag.PageSize == 25)">25</option>
                        <option value="50" selected="@(ViewBag.PageSize == 50)">50</option>
                    </select>
                </div>

                <div class="col-md-2 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-outline-primary w-100">Filtrer</button>
                    <a asp-action="Index" class="btn btn-light w-100">Reset</a>
                </div>

            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">

            @if (!suppliers.Any())
            {
                <div class="alert alert-info mb-0">Aucun fournisseur trouvé.</div>
            }
            else
            {
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Nom</th>
                            <th>Email</th>
                            <th>Téléphone</th>
                            <th>Produits</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var supplier in suppliers)
                        {
                            <tr>
                                <td>
                                    <a asp-action="Details" asp-route-id="@supplier.Id" class="fw-semibold text-decoration-none">
                                        @supplier.Name
                                    </a>
                                </td>

                                <td>@(supplier.Email ?? "-")</td>
                                <td>@(supplier.Phone ?? "-")</td>
                                <td>@(supplier.Products?.Count ?? 0)</td>

                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@supplier.Id" class="btn btn-sm btn-outline-secondary">Voir</a>
                                    <a asp-action="Edit" asp-route-id="@supplier.Id" class="btn btn-sm btn-outline-primary">Modifier</a>
                                    <a asp-action="Delete" asp-route-id="@supplier.Id" class="btn btn-sm btn-outline-danger">Supprimer</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

        </div>
    </div>
</div>
