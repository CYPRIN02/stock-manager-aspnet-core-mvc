@model StockManager.Web.Models.Supplier

@{
    ViewData["Title"] = "Ajouter fournisseur";
}

<div class="container py-4">
    <h1 class="fw-bold">Modifier un fournisseur</h1>

    <div class="card border-0 shadow-sm rounded-4 mt-3">
        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Nom</label>
                    <input asp-for="Name" class="form-control" placeholder="Ex : Dell France" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" placeholder="contact@fournisseur.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Phone" class="form-label">Téléphone</label>
                    <input asp-for="Phone" class="form-control" placeholder="01 23 45 67 89" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-light">Annuler</a>
                    <button type="submit" class="btn btn-primary">Enregistrer</button>
                </div>
            </form>
        </div>
    </div>
</div>