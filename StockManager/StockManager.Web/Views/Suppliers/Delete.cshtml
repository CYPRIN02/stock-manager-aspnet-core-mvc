@model StockManager.Web.Models.Supplier

@{
    ViewData["Title"] = "Supprimer fournisseur";
}

<div class="container py-4">
    <h1 class="fw-bold text-danger">Supprimer fournisseur</h1>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <p>Voulez-vous vraiment supprimer ce fournisseur ?</p>

            <h4>@Model.Name</h4>
            <p class="text-muted">Produits associés : @(Model.Products?.Count ?? 0)</p>

            @if (Model.Products != null && Model.Products.Any())
            {
                <div class="alert alert-warning">
                    Ce fournisseur est lié à des produits. La suppression sera bloquée.
                </div>
            }

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-light">Annuler</a>
                    <button type="submit" class="btn btn-danger">Confirmer suppression</button>
                </div>
            </form>
        </div>
    </div>
</div>