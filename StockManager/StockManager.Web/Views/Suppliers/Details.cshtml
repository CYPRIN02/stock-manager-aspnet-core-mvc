@model StockManager.Web.Models.Supplier

@{
    ViewData["Title"] = "Détail fournisseur";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold">@Model.Name</h1>
            <p class="text-muted">Détail du fournisseur</p>
        </div>

        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Modifier</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Supprimer</a>
            <a asp-action="Index" class="btn btn-light">Retour</a>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <h5 class="fw-bold">Informations</h5>
            <p><strong>Nom :</strong> @Model.Name</p>
            <p><strong>Email :</strong> @(Model.Email ?? "-")</p>
            <p><strong>Téléphone :</strong> @(Model.Phone ?? "-")</p>
            <p><strong>Nombre de produits :</strong> @(Model.Products?.Count ?? 0)</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <h5 class="fw-bold mb-3">Produits liés</h5>

            @if (Model.Products == null || !Model.Products.Any())
            {
                <div class="alert alert-info mb-0">Aucun produit lié à ce fournisseur.</div>
            }
            else
            {
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Référence</th>
                            <th>Produit</th>
                            <th>Catégorie</th>
                            <th>Quantité</th>
                            <th>Prix</th>
                            <th>Statut</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var product in Model.Products.OrderBy(p => p.Name))
                        {
                            var isLowStock = product.Quantity <= product.AlertThreshold;

                            <tr>
                                <td>@product.Reference</td>
                                <td>
                                    <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" class="text-decoration-none fw-semibold">
                                        @product.Name
                                    </a>
                                </td>
                                <td>@(product.Category?.Name ?? "-")</td>
                                <td>@product.Quantity</td>
                                <td>@product.UnitPrice.ToString("C")</td>
                                <td>
                                    @if (isLowStock)
                                    {
                                        <span class="badge bg-danger">Alerte</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">OK</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>