@using Microsoft.AspNetCore.Identity
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StockManager.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/StockManager.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-primary d-flex align-items-center gap-2"
                   asp-controller="Home"
                   asp-action="Index">
                    <i class="bi bi-box-seam-fill fs-4"></i>
                    AmadagoIT
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>
            </div>
             <ul class="navbar-nav flex-grow-1">
                <li class="nav-item">
                    <a class="nav-link text-dark" asp-controller="Dashboard" asp-action="Index">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-dark" asp-controller="Products" asp-action="Index">
                        <i class="bi bi-box-seam"></i> Produits
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-dark" asp-controller="Categories" asp-action="Index">
                        <i class="bi bi-tags"></i> Catégories
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-dark" asp-controller="Suppliers" asp-action="Index">
                        <i class="bi bi-truck"></i> Fournisseurs
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-dark" asp-controller="StockMovements" asp-action="Index">
                        <i class="bi bi-arrow-left-right"></i> Mouvements
                    </a>
                </li>
            </ul>

        </nav>

        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle"
                   data-bs-toggle="dropdown"
                   href="#">
                    👤 @User.Identity.Name
                </a>

                <ul class="dropdown-menu dropdown-menu-end">
                    <li>
                        <span class="dropdown-item-text">
                            @if (User.IsInRole("Admin"))
                            {
                                <span class="badge bg-danger">Admin</span>
                            }
                            else if (User.IsInRole("Manager"))
                            {
                                <span class="badge bg-warning">Manager</span>
                            }
                            else
                            {
                                <span class="badge bg-info">Employee</span>
                            }
                        </span>
                    </li>

                    <li><hr class="dropdown-divider"></li>

                    <li>
                        <form asp-area="Identity"
                              asp-page="/Account/Logout"
                              method="post">
                            <button class="dropdown-item">
                                Déconnexion
                            </button>
                        </form>
                    </li>
                </ul>
            </li>
        }
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - StockManager.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <button onclick="scrollToTop()" id="backToTopBtn" title="Remonter">
        ↑
    </button>
</body>
</html>
